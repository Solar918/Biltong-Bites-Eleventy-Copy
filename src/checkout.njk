---
layout: layouts/base.njk
title: Checkout
description: Enter your details to receive an order confirmation email
---

<article class="container checkout-page">
  <header>
    <h1>Checkout</h1>
  </header>
  <form id="checkout-form">
    <div class="form-row">
      <div>
        <label for="name">First and Last Name</label>
        <input type="text" id="name" name="name" required />
      </div>
      <div>
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" name="phone" required />
      </div>
    </div>
    <label for="email">Email Address</label>
    <input type="email" id="email" name="email" required style="margin-bottom: 1.5rem;" />
    <button type="submit" class="btn">Place Order & Send Email</button>
  </form>
  <div id="email-preview" class="email-preview"></div>
  <a href="/cart/" class="btn btn-ghost">Back to cart</a>
</article>
